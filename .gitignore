# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Data artifacts
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/interim/*

# Archived datasets (pre-Meltemi Codex/Gemini data, quarantined, DO NOT reuse)
data/archive_*/

# Environment and secrets
.env
.env.*

# External model/runtime assets
external/
checkpoints/base/

# Generated artefacts.
# Large / heavy outputs (model checkpoints, raw logs, .txt debug dumps)
# stay out of git. Small audit-evidence JSONs (manifests + metrics
# reports) ARE committed so anyone cloning the repo can verify a
# downloaded dataset without running the full pipeline.
artifacts/logs/
artifacts/model/
artifacts/checkpoints/
artifacts/*.txt
artifacts/**/*.txt
artifacts/*.json
!artifacts/manifest/*.json
!artifacts/metrics/*.json

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/

# Claude Code per-user settings
.claude/settings.local.json
.playwright-mcp/

# Controller-private records.
# Operational identifiers (AWS account ID, S3 bucket name, IAM user/role
# names, instance IDs, spot-request IDs), the provider-side filled
# Article 30 ROPA, and any DPIA detail that is not appropriate for a
# public repository live under private/. Only private/README.md is
# tracked, as a stub explaining the directory structure for forks /
# reproductions.
private/*
!private/README.md
